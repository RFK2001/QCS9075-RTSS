[Unit]
Description=Audio adsprpc Service
SourcePath=/usr/bin/audioadsprpcd

[Service]
User=audioadsprpcd
Group=kmem fastrpc
Restart=on-failure
ExecStart=/usr/bin/audioadsprpcd audiopd

[Install]
WantedBy=multi-user.target

